generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
}

model Inventory {
  id           String   @id @default(cuid())
  codProd      Int
  descricao    String
  createdAt    DateTime @default(now())
  count        Int
  inStock      Int
  inplantedDate  DateTime?
  userEmail    String
  localizacao String @default("Z-000")
}

model RewardsFidelimax {
  idVoucher String   @id
  cpf       String   @db.VarChar(11)
  value     Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(dbgenerated("(now() - '03:00:00'::interval)")) @db.Timestamptz(6)

  @@index([cpf])
}

model DebitInvalidLog {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  cpf              String
  debitoReais      Decimal  @db.Decimal(12, 2)
  descricaoEstorno String?
  dataMov          DateTime
  nome             String?
  documento        String?
  codigoResposta   Int?
  nunota           String?
  rawResponse      Json?

  @@index([cpf])
  @@index([codigoResposta])
  @@index([dataMov])
}

enum Role {
  ADMIN
  MANAGER
  USER
}
