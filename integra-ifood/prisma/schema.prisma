generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  acessos      String[]
}

model Inventory {
  codProd       Int
  descricao     String
  createdAt     DateTime  @default(now())
  count         Int
  inStock       Int
  inplantedDate DateTime?
  userEmail     String
  id            String    @id @default(cuid())
  localizacao   String    @default("Z-000")
  reservado     Int?
  recontagem    Boolean?  @default(false)
  localizacao2  String?   @default("Z-000")
  diferenca     Int?
  inNote        Boolean?  @default(false)
}

model AcompanhamentoPedido {
  id            String   @id @default(cuid())
  nunota        String   @unique
  status        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  liberado      DateTime?
  fila          DateTime?
  separacao     DateTime?
  conferencia   DateTime?
}

model Auditoria {
  codProd       Int
  descricao     String
  createdAt     DateTime  @default(now())
  count         Int
  inStock       Int
  userEmail     String
  id            String    @id @default(cuid())
  reservado     Int
  diferenca     Int
}

model NotFound {
  id              String @id @default(cuid())
  localizacao     String @unique
  codProdContados Int[]
  codProdFaltando Int[]
}

model RewardsFidelimax {
  idVoucher String   @id
  cpf       String   @db.VarChar(11)
  value     Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(dbgenerated("(now() - '03:00:00'::interval)")) @db.Timestamptz(6)

  @@index([cpf])
}

model DebitInvalidLog {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  cpf              String
  debitoReais      Decimal  @db.Decimal(12, 2)
  descricaoEstorno String?
  dataMov          DateTime
  nome             String?
  documento        String?
  codigoResposta   Int?
  nunota           String?
  rawResponse      Json?

  @@index([cpf])
  @@index([codigoResposta])
  @@index([dataMov])
}

model Pedidos {
  id          Int               @id @default(autoincrement())
  createdAt   DateTime          @default(now())
  customer    String?
  status      String?
  items       PedidoItem[]
  separadores PedidoSeparador[]
}

model PedidoSeparador {
  id        Int          @id @default(autoincrement())
  pedidoId  Int
  separador String
  area      String
  createdAt DateTime     @default(now())
  status    String
  items     PedidoItem[]
  order     Pedidos      @relation(fields: [pedidoId], references: [id])

  @@index([pedidoId])
}

model PedidoItem {
  id          String          @id @default(cuid())
  separadorId Int
  pedidoId    Int
  codProd     String
  qnt         Int
  status      Boolean         @default(false)
  order       Pedidos         @relation(fields: [pedidoId], references: [id])
  separador   PedidoSeparador @relation(fields: [separadorId], references: [id])

  @@index([pedidoId])
  @@index([codProd])
}

model Estoque {
  id          String   @id @default(cuid())
  region      String   @unique
  separadores String[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String   @unique
  lastSeen  DateTime @default(now())
  expiresAt DateTime
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([active])
  @@index([lastSeen])
}

model Solicitacao {
  id          String            @id @default(cuid())
  userRequest String
  userAproved String            @default(" ")
  aprovado    Boolean           @default(false)
  resposta    Boolean?
  createdAt   DateTime          @default(now())
  aprovedAt   DateTime?
  items       ItemSolicitacao[]
}

model ItemSolicitacao {
  id            String      @id @default(cuid())
  codProd       Int
  quantidade    Int
  descricao     String
  solicitacaoId String
  solicitacao   Solicitacao @relation(fields: [solicitacaoId], references: [id])
}

model ErroEstoque {
  id        String   @id @default(cuid())
  codProd   Int
  descricao String
  createdAt DateTime @default(now())
  userCreate String
  resolvido Boolean  @default(false)
  resposta  String?
  userResolve String?
  resolvedAt DateTime?

}

model CurvaProduto {
  id            String     @id @default(cuid())
  codProd       Int     @unique
  curvaProduto  String   // A/B/C/D
  descricao     String
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
}

model LogSync {
  id        String   @id @default(cuid())
  syncType  String
  status    String
  message   String?
  createdAt DateTime @default(now())
  userEmail String
}

model MercadoLivreVendedor{
  id            BigInt   @id @default(autoincrement())
  MLUserId      BigInt   @unique @map("ml_user_id")
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  expiresAt    BigInt   @map("expires_at")
  scope        String?  @db.Text
  tokenType    String?  @map("token_type")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  orderLinks   MlPedidoLink[]
  skuMaps      MlSkuMap[]

  @@index([expiresAt], map: "idx_ml_sellers_expires_at")
  @@map("ml_sellers")

}


model MlPedidoLink {
  id           BigInt        @id @default(autoincrement())

  sellerId     BigInt        @map("seller_id")
  seller       MercadoLivreVendedor      @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  /// ID do pedido no ML
  mlOrderId    BigInt        @map("ml_order_id")

  /// NUNOTA no Sankhya (pode ser null até criar)
  sankhyaNunota BigInt?      @map("sankhya_nunota")

  /// TOP usada na integração (default 601)
  top          Int           @default(601)

  status       MlOrderStatus @default(created)
  lastError    String?       @db.Text @map("last_error")
  attempts     Int           @default(0)

  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  /// Idempotência: 1 pedido por seller
  @@unique([sellerId, mlOrderId], map: "uq_ml_order_links_seller_order")
  @@index([status], map: "idx_ml_order_links_status")
  @@index([sankhyaNunota], map: "idx_ml_order_links_sankhya_nunota")
  @@index([updatedAt], map: "idx_ml_order_links_updated_at")
  @@map("ml_order_links")
}

model MlSkuMap {
  id         BigInt   @id @default(autoincrement())

  sellerId   BigInt   @map("seller_id")
  seller     MercadoLivreVendedor @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  /// SKU do seller no ML (o que vem no order item)
  sellerSku  String   @db.VarChar(80) @map("seller_sku")

  /// CODPROD no Sankhya
  codprod    BigInt   @map("codprod")

  active     Boolean  @default(true)

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([sellerId, sellerSku], map: "uq_ml_sku_map_seller_sku")
  @@index([codprod], map: "idx_ml_sku_map_codprod")
  @@map("ml_sku_map")
}

model itensList{
  id         Int @id @default(autoincrement())
  tipo       String @unique
  valores    String[]

}

model Localizacoes{
  Id            String    @id @default(cuid())
  Rua           String
  Predio        String
  Nivel         String
  Apartamento   String
  Endereco      String    @unique
  Armazenamento String    @unique
}

model CodigosRoleta{
  id     String @id @default(cuid())
  codigo String @unique
  usado  Boolean @default(false)
}

model DemandasTI{
  id            Int @id @default(autoincrement())
  solicitacao   String
  descricao     String
  andamento     AndamentoDemanda @default(Aberto)
  dataAbertura  DateTime @default(now())
  comentario    String?
  dataAlteracao DateTime?
}

model RegrasAliquota{
  id              Int @id @default(autoincrement())
  descricao       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime @updatedAt
  aliquota        String?
  cfop            String
  tributacao      String
  aliquotaICMS    String?
  baseICMS        String?

}

model NCM {
  id           Int @id @default(autoincrement())
  ncm          String @unique
  descricao    String?
  mva4         String?
  mva7         String?
  mva12        String?
  
}


model ClienteClube {
  id        String   @id @default(cuid())
  nome      String
  cpf       String   @unique
  senha     String
  codParc   String   @unique
  email     String   @unique
  telefone  String
  pontos    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações bidirecionais corrigidas
  resgates  ResgateClube[] 
  notas     NotasPontuadas[]
}

model ResgateClube {
  id        String   @id @default(cuid())
  codParc   String       
  pontos    Int      @default(0)
  codigo    String   @unique
  codProd   String?
  nunota    String   @unique
  status    String   @default("PENDENTE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cliente   ClienteClube @relation(fields: [codParc], references: [codParc])
  premio    PremioClube @relation(fields: [codigo], references: [codigo])

}

model NotasPontuadas {
  id        String   @id @default(cuid())
  codParc   String       
  pontos    Int      @default(0)
  nunota    String   @unique
  tipo      TipoNotaClube
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cliente   ClienteClube @relation(fields: [codParc], references: [codParc])


}

model PremioClube{
  id        String   @id @default(cuid())
  nome      String
  codigo    String   @unique
  codProd   String?
  pontos    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  resgates  ResgateClube[]
  

}

enum TipoNotaClube {
  COMPRA
  DEVOLUCAO

}

enum AndamentoDemanda {
  Aberto
  EmAndamento
  Finalizado
  Abandonado
  Pausado

}

enum Role {
  ADMIN
  MANAGER
  USER
  TRIAGEM
  SEPARADOR
  ESTOQUE
  CONTADOR
  SUPERVISOR
  AUDITOR
}


enum MlOrderStatus {
  created
  processing
  done
  error
  retrying
  canceled
}
