generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
}


model Inventory {
  id             String   @id @default(cuid())
  codProd        Int
  descricao      String
  createdAt      DateTime @default(now())
  count          Int
  inStock        Int
  inplantedDate  DateTime?
  userEmail      String
  localizacao    String @default("Z-000")
  localizacao2   String? @default("Z-000")
  reservado      Int?
  recontagem     Boolean? @default(false)
}

model NotFound{
  id             String   @id @default(cuid())
  localizacao String @unique
  codProdContados        Int[]
  codProdFaltando        Int[]
}

model RewardsFidelimax {
  idVoucher String   @id
  cpf       String   @db.VarChar(11)
  value     Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(dbgenerated("(now() - '03:00:00'::interval)")) @db.Timestamptz(6)

  @@index([cpf])
}

model DebitInvalidLog {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  cpf              String
  debitoReais      Decimal  @db.Decimal(12, 2)
  descricaoEstorno String?
  dataMov          DateTime
  nome             String?
  documento        String?
  codigoResposta   Int?
  nunota           String?
  rawResponse      Json?

  @@index([cpf])
  @@index([codigoResposta])
  @@index([dataMov])
}


model Pedidos {
  id          Int         @id @default(autoincrement())
  createdAt   DateTime    @default(now())
  customer    String?     
  status      String?     
  items       PedidoItem[]
  separadores PedidoSeparador[] // relação 1:N
}

model PedidoSeparador {
  id        Int     @id @default(autoincrement())
  order     Pedidos   @relation(fields: [pedidoId], references: [id])
  pedidoId  Int
  separador String
  area      String
  status    String
  createdAt DateTime @default(now())
  items     PedidoItem[]

  @@index([pedidoId])
}

model PedidoItem{
  id          String          @id @default(cuid())
  separador   PedidoSeparador @relation(fields: [separadorId], references: [id])
  separadorId Int
  order       Pedidos         @relation(fields: [pedidoId], references: [id])
  pedidoId    Int
  codProd     String
  qnt         Int
  status      Boolean         @default(false)

  @@index([pedidoId])
  @@index([codProd])
}

model Estoque {
  id        String     @id @default(cuid())
  region    String     @unique
  separadores String[]
}

model Session {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String  @unique
  lastSeen   DateTime @default(now())
  expiresAt  DateTime
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  

  @@index([userId])
  @@index([active])
  @@index([lastSeen])
}

enum Role {
  MANAGER // DEV-ONLY
  ADMIN // DANILO
  USER // USUARIO PADRÃO
  TRIAGEM // TRIAGEM
  SEPARADOR // SEPARADORES
  ESTOQUE // ALISSON BRUNO
   
}

