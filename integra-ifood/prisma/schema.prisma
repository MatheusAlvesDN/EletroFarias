generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  passwordHash     String
  role             Role             @default(USER)
  createdAt        DateTime         @default(now())
  acessos          String[]
  crmTags          String[]
  codVend          String?          @unique
  crmAgendas       CrmAgenda[]
  clientesCarteira CrmCliente[]     @relation("CarteiraClientes")
  crmComentarios   CrmComentario[]
  crmLeads         CrmLead[]
  notificacoes     CrmNotificacao[]
  crmPedidos       CrmPedido[]
  receivedMessages Message[]        @relation("ReceivedMessages")
  sentMessages     Message[]        @relation("SentMessages")
}

model Inventory {
  codProd       Int
  descricao     String
  createdAt     DateTime  @default(now())
  count         Int
  inStock       Int
  inplantedDate DateTime?
  userEmail     String
  id            String    @id @default(cuid())
  localizacao   String    @default("Z-000")
  reservado     Int?
  recontagem    Boolean?  @default(false)
  localizacao2  String?   @default("Z-000")
  diferenca     Int?
  inNote        Boolean?  @default(false)
}

model AcompanhamentoPedido {
  id          String    @id @default(cuid())
  nunota      String    @unique
  status      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  liberado    DateTime?
  fila        DateTime?
  separacao   DateTime?
  conferencia DateTime?
}

model MercadoLivreToken {
  id           Int      @id @default(autoincrement())
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  expiresIn    Int      @map("expires_in")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("mercadolivretoken")
}

model MlProduto {
  id             BigInt   @id @default(autoincrement())
  codProd        Int      @unique @map("codprod")
  descrProd      String   @map("descrprod")
  codBarra       String?  @map("codbarra")
  codGrupoProd   Int?     @map("codgrupoprod")
  descrGrupoProd String?  @map("descrgrupoprod")
  marca          String?
  ativo          Boolean  @default(true)
  preco          Decimal? @db.Decimal(14, 2)
  estoque        Int      @default(0)
  selecionado    Boolean  @default(false)
  payload        Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([selecionado], map: "idx_ml_produtos_selecionado")
  @@map("ml_produtos")
}

model DfariasOrcamento {
  id                   Int                    @id @default(autoincrement())
  nome                 String                 @db.VarChar(150)
  totalItens           Int                    @default(0)
  totalPreenchidos     Int                    @default(0)
  layout               Json
  criadoEm             DateTime               @default(now())
  atualizadoEm         DateTime               @updatedAt
  orcamentoEstruturado Json?
  prazoEntrega         Int?
  quadros              Json?
  totalQuadros         Int                    @default(1)
  leadId               String?
  itens                DfariasOrcamentoItem[]
  lead                 CrmLead?               @relation(fields: [leadId], references: [id])

  @@map("dfarias_orcamentos")
}

model DfariasOrcamentoItem {
  id          Int              @id @default(autoincrement())
  orcamentoId Int
  categoria   String           @db.VarChar(20)
  produto     String           @db.VarChar(200)
  qtd         Decimal          @db.Decimal(18, 2)
  unidade     String           @db.VarChar(20)
  orcamento   DfariasOrcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)

  @@index([orcamentoId])
  @@map("dfarias_orcamento_itens")
}

model Auditoria {
  codProd   Int
  descricao String
  createdAt DateTime @default(now())
  count     Int
  inStock   Int
  userEmail String
  id        String   @id @default(cuid())
  reservado Int
  diferenca Int
}

model NotFound {
  id              String @id @default(cuid())
  localizacao     String @unique
  codProdContados Int[]
  codProdFaltando Int[]
}

model RewardsFidelimax {
  idVoucher String   @id
  cpf       String   @db.VarChar(11)
  value     Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(dbgenerated("(now() - '03:00:00'::interval)")) @db.Timestamptz(6)

  @@index([cpf])
}

model DebitInvalidLog {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  cpf              String
  debitoReais      Decimal  @db.Decimal(12, 2)
  descricaoEstorno String?
  dataMov          DateTime
  nome             String?
  documento        String?
  codigoResposta   Int?
  nunota           String?
  rawResponse      Json?

  @@index([cpf])
  @@index([codigoResposta])
  @@index([dataMov])
}

model Pedidos {
  id          Int               @id @default(autoincrement())
  createdAt   DateTime          @default(now())
  customer    String?
  status      String?
  items       PedidoItem[]
  separadores PedidoSeparador[]
}

model PedidoSeparador {
  id        Int          @id @default(autoincrement())
  pedidoId  Int
  separador String
  area      String
  createdAt DateTime     @default(now())
  status    String
  items     PedidoItem[]
  order     Pedidos      @relation(fields: [pedidoId], references: [id])

  @@index([pedidoId])
}

model PedidoItem {
  id          String          @id @default(cuid())
  separadorId Int
  pedidoId    Int
  codProd     String
  qnt         Int
  status      Boolean         @default(false)
  order       Pedidos         @relation(fields: [pedidoId], references: [id])
  separador   PedidoSeparador @relation(fields: [separadorId], references: [id])

  @@index([pedidoId])
  @@index([codProd])
}

model Estoque {
  id          String   @id @default(cuid())
  region      String   @unique
  separadores String[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String   @unique
  lastSeen  DateTime @default(now())
  expiresAt DateTime
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([active])
  @@index([lastSeen])
}

model Solicitacao {
  id          String            @id @default(cuid())
  userRequest String
  userAproved String            @default(" ")
  aprovado    Boolean           @default(false)
  createdAt   DateTime          @default(now())
  aprovedAt   DateTime?
  resposta    Boolean?
  items       ItemSolicitacao[]
}

model ItemSolicitacao {
  id            String      @id @default(cuid())
  codProd       Int
  quantidade    Int
  descricao     String
  solicitacaoId String
  solicitacao   Solicitacao @relation(fields: [solicitacaoId], references: [id])
}

model ErroEstoque {
  id          String    @id @default(cuid())
  codProd     Int
  descricao   String
  createdAt   DateTime  @default(now())
  userCreate  String
  resolvido   Boolean   @default(false)
  userResolve String?
  resolvedAt  DateTime?
  resposta    String?
}

model CurvaProduto {
  codProd      Int      @unique
  curvaProduto String
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
  descricao    String
  id           String   @id @default(cuid())
}

model LogSync {
  id        String   @id @default(cuid())
  syncType  String
  status    String
  message   String?
  createdAt DateTime @default(now())
  userEmail String
}

model MercadoLivreVendedor {
  id           BigInt         @id @default(autoincrement())
  MLUserId     BigInt         @unique @map("ml_user_id")
  accessToken  String         @map("access_token")
  refreshToken String         @map("refresh_token")
  expiresAt    BigInt         @map("expires_at")
  scope        String?
  tokenType    String?        @map("token_type")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  orderLinks   MlPedidoLink[]
  skuMaps      MlSkuMap[]

  @@index([expiresAt], map: "idx_ml_sellers_expires_at")
  @@map("ml_sellers")
}

model MlPedidoLink {
  id            BigInt               @id @default(autoincrement())
  sellerId      BigInt               @map("seller_id")
  /// ID do pedido no ML
  mlOrderId     BigInt               @map("ml_order_id")
  /// NUNOTA no Sankhya (pode ser null até criar)
  sankhyaNunota BigInt?              @map("sankhya_nunota")
  /// TOP usada na integração (default 601)
  top           Int                  @default(601)
  status        MlOrderStatus        @default(created)
  lastError     String?              @map("last_error")
  attempts      Int                  @default(0)
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  seller        MercadoLivreVendedor @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, mlOrderId], map: "uq_ml_order_links_seller_order")
  @@index([status], map: "idx_ml_order_links_status")
  @@index([sankhyaNunota], map: "idx_ml_order_links_sankhya_nunota")
  @@index([updatedAt], map: "idx_ml_order_links_updated_at")
  @@map("ml_order_links")
}

model MlSkuMap {
  id        BigInt               @id @default(autoincrement())
  sellerId  BigInt               @map("seller_id")
  /// SKU do seller no ML (o que vem no order item)
  sellerSku String               @map("seller_sku") @db.VarChar(80)
  /// CODPROD no Sankhya
  codprod   BigInt               @map("codprod")
  active    Boolean              @default(true)
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")
  seller    MercadoLivreVendedor @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, sellerSku], map: "uq_ml_sku_map_seller_sku")
  @@index([codprod], map: "idx_ml_sku_map_codprod")
  @@map("ml_sku_map")
}

model itensList {
  id      Int      @id @default(autoincrement())
  tipo    String   @unique
  valores String[]
}

model Localizacoes {
  Id            String @id @default(cuid())
  Rua           String
  Predio        String
  Nivel         String
  Endereco      String @unique
  Armazenamento String @unique
  Apartamento   String
}

model CodigosRoleta {
  id     String  @id @default(cuid())
  codigo String  @unique
  usado  Boolean @default(false)
}

model DemandasTI {
  solicitacao   String
  descricao     String
  comentario    String?
  dataAbertura  DateTime         @default(now())
  dataAlteracao DateTime?
  andamento     AndamentoDemanda @default(Aberto)
  id            Int              @id @default(autoincrement())
}

model RegrasAliquota {
  id           Int      @id @default(autoincrement())
  descricao    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  aliquota     String?
  cfop         String
  tributacao   String
  aliquotaICMS String?
  baseICMS     String?
}

model NCM {
  id        Int     @id @default(autoincrement())
  ncm       String  @unique
  descricao String?
  mva4      String?
  mva7      String?
  mva12     String?
}

model ClienteClube {
  id        String           @id @default(cuid())
  nome      String
  cpf       String           @unique
  codParc   String           @unique
  email     String           @unique
  telefone  String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  pontos    Int              @default(0)
  senha     String
  notas     NotasPontuadas[]
  resgates  ResgateClube[]
}

model ResgateClube {
  id         String       @id @default(cuid())
  codParc    String
  pontos     Int          @default(0)
  nunota     String       @unique
  status     String       @default("PENDENTE")
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  codProd    String?
  codigo     String
  quantidade Int          @default(1)
  cliente    ClienteClube @relation(fields: [codParc], references: [codParc])
  premio     PremioClube  @relation(fields: [codigo], references: [codigo])
}

model NotasPontuadas {
  id        String        @id @default(cuid())
  codParc   String
  pontos    Int           @default(0)
  nunota    String        @unique
  tipo      TipoNotaClube
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  cliente   ClienteClube  @relation(fields: [codParc], references: [codParc])
}

model PremioClube {
  id        String         @id @default(cuid())
  nome      String
  codigo    String         @unique
  codProd   String?
  pontos    Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  resgates  ResgateClube[]
}

model CrmCliente {
  id         String      @id @default(cuid())
  nome       String
  email      String?
  telefone   String?
  documento  String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  codParc    String?     @unique
  vendedorId String?
  vendedor   User?       @relation("CarteiraClientes", fields: [vendedorId], references: [id])
  leads      CrmLead[]
  pedidos    CrmPedido[]
}

model CrmLead {
  id              String          @id @default(cuid())
  vendedorId      String?
  clienteId       String
  status          CrmStatus       @default(PROSPECCAO)
  titulo          String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  tag             String?         @default("LID")
  motivoPerda     String?
  statusUpdatedAt DateTime        @default(now())
  observacaoPerda String?
  agendas         CrmAgenda[]
  comentarios     CrmComentario[]
  cliente         CrmCliente      @relation(fields: [clienteId], references: [id])
  vendedor        User?           @relation(fields: [vendedorId], references: [id])
  anexos          CrmLeadAnexo[]
  pedidos         CrmPedido[]
  projects        DfariasOrcamento[]
}

model CrmLeadAnexo {
  id        String   @id @default(cuid())
  leadId    String
  nome      String
  url       String
  tipo      String?
  tamanho   Int?
  createdAt DateTime @default(now())
  lead      CrmLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model CrmPedido {
  id          String           @id @default(cuid())
  numero      Int              @unique @default(autoincrement())
  userId      String
  clienteId   String
  status      CrmStatus        @default(PROSPECCAO)
  valorTotal  Decimal          @default(0) @db.Decimal(14, 2)
  observacoes String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  nunota      Int?
  leadId      String?
  comentarios CrmComentario[]
  cliente     CrmCliente       @relation(fields: [clienteId], references: [id])
  lead        CrmLead?         @relation(fields: [leadId], references: [id])
  vendedor    User             @relation(fields: [userId], references: [id])
  anexos      CrmPedidoAnexo[]
  itens       CrmPedidoItem[]
}

model CrmComentario {
  id        String     @id @default(cuid())
  pedidoId  String?
  userId    String
  texto     String
  createdAt DateTime   @default(now())
  leadId    String?
  lead      CrmLead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  pedido    CrmPedido? @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  usuario   User       @relation(fields: [userId], references: [id])
}

model CrmAgenda {
  id           String   @id @default(cuid())
  userId       String
  titulo       String
  descricao    String?
  dataAgendada DateTime
  concluido    Boolean  @default(false)
  notificado   Boolean  @default(false)
  createdAt    DateTime @default(now())
  notificado1h Boolean  @default(false)
  leadId       String
  lead         CrmLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  usuario      User     @relation(fields: [userId], references: [id])
}

model CrmNotificacao {
  id        String   @id @default(cuid())
  userId    String
  titulo    String
  mensagem  String
  lida      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  usuario   User     @relation(fields: [userId], references: [id])
}

model CrmPedidoItem {
  id            String    @id @default(cuid())
  pedidoId      String
  codProd       Int
  descricao     String
  quantidade    Int
  precoUnitario Decimal   @db.Decimal(14, 2)
  precoTotal    Decimal   @db.Decimal(14, 2)
  pedido        CrmPedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
}

model CrmPedidoAnexo {
  id        String    @id @default(cuid())
  pedidoId  String
  nome      String
  url       String
  tipo      String?
  tamanho   Int?
  createdAt DateTime  @default(now())
  pedido    CrmPedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
}

model CrmProduto {
  id         String   @id @default(cuid())
  codProd    String   @unique
  descricao  String
  precoVenda Decimal  @db.Decimal(14, 2)
  estoque    Int      @default(0)
  categoria  String?
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

enum CrmStatus {
  PROSPECCAO
  ORCAMENTO
  NEGOCIACAO
  APROVADO
  REPROVADO
  FATURADO
  PLANTA_CODIFICADA
  MEMORIAL_DESCRITIVO
  EM_PRODUCAO
  POS_VENDA
}

enum TipoNotaClube {
  COMPRA
  DEVOLUCAO
  BONUS
  AJUSTE
}

enum AndamentoDemanda {
  Aberto
  EmAndamento
  Finalizado
  Abandonado
  Pausado
}

enum Role {
  ADMIN
  MANAGER
  USER
  TRIAGEM
  SEPARADOR
  ESTOQUE
  CONTADOR
  SUPERVISOR
  AUDITOR
  VENDEDOR
  GERENTE
}

enum MlOrderStatus {
  created
  processing
  done
  error
  retrying
  canceled
}
