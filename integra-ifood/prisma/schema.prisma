// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  USER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
}

model Fidelimax_CodProd {
  codProd           Int     @id
  produto           String     @unique
}

model DebitInvalidLog {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())

  // do request original
  cpf              String
  debitoReais      Decimal  @db.Decimal(12, 2)  // <- aqui
  descricaoEstorno String?
  dataMov          DateTime

  // do response da API
  nome             String?
  documento        String?
  saldoPreEstorno  Decimal? @db.Decimal(14, 2)  // <- e aqui
  pontosEstornados Int?
  codigoResposta   Int
  nunota           String?
  rawResponse      Json?

  @@index([cpf])
  @@index([codigoResposta])
  @@index([dataMov])
}
